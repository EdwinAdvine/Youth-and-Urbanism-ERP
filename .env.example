# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=urban
POSTGRES_PASSWORD=urban_secret
# PRODUCTION: openssl rand -hex 16
POSTGRES_DB=urban_vibes_dynamics
DATABASE_URL=postgresql+asyncpg://urban:urban_secret@postgres:5432/urban_vibes_dynamics

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
# PRODUCTION: set a password and update REDIS_URL to redis://:YOUR_PASSWORD@redis:6379/0

# ─── Security / JWT ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# PRODUCTION: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Backup Encryption ────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=
# PRODUCTION: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── AI ────────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# PRODUCTION: openssl rand -hex 16 for both
MINIO_BUCKET=urban-vibes-dynamics-files

# ─── App ───────────────────────────────────────────────────────────────────
APP_NAME=Urban Vibes Dynamics
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DEBUG=true

# ─── First Super Admin (created on first startup) ─────────────────────────
FIRST_SUPERADMIN_EMAIL=super-admin@youthandurbanism.org
FIRST_SUPERADMIN_PASSWORD=super-admin@2026!
# PRODUCTION: use a strong, unique password

# ─── ONLYOFFICE ────────────────────────────────────────────────────────────
ONLYOFFICE_JWT_SECRET=onlyoffice-jwt-secret-2026-urban-vibes-dynamics
# PRODUCTION: openssl rand -hex 32

# ─── Jitsi ─────────────────────────────────────────────────────────────────
JICOFO_COMPONENT_SECRET=jitsi-jicofo-secret
JICOFO_AUTH_PASSWORD=jitsi-focus-password
JVB_AUTH_PASSWORD=jitsi-jvb-password
# PRODUCTION: openssl rand -hex 16 for each

# ─── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# PRODUCTION: include Redis password — redis://:YOUR_PASSWORD@redis:6379/1

# ─── Mail ──────────────────────────────────────────────────────────────────
MAIL_DOMAIN=youthandurbanism.org
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
