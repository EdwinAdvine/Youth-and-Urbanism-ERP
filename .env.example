# Database
POSTGRES_USER=urban
POSTGRES_PASSWORD=urban_secret
POSTGRES_DB=urban_erp
DATABASE_URL=postgresql+asyncpg://urban:urban_secret@postgres:5432/urban_erp

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=

# MinIO
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=urban-erp-files

# App
APP_NAME=Urban ERP
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# First Super Admin (created on first startup)
FIRST_SUPERADMIN_EMAIL=super-admin@youthandurbanism.org
FIRST_SUPERADMIN_PASSWORD=super-admin@2026!

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
