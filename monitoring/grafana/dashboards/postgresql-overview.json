{
  "__inputs": [],
  "__requires": [{"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"}],
  "annotations": {"list": []},
  "description": "Urban Vibes Dynamics — PostgreSQL cluster overview: connections, transactions/s, cache hit ratio, table sizes",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 150}, {"color": "red", "value": 190}]}, "unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Active Connections",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_activity_count{datname=\"urban_erp\",state=\"active\"}", "legendFormat": "active", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.95}]}, "unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Cache Hit Ratio",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_database_blks_hit{datname=\"urban_erp\"} / (pg_stat_database_blks_hit{datname=\"urban_erp\"} + pg_stat_database_blks_read{datname=\"urban_erp\"})", "legendFormat": "hit ratio", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Database Size",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_database_size_bytes{datname=\"urban_erp\"}", "legendFormat": "size", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Transactions/s",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_xact_commit{datname=\"urban_erp\"}[5m]) + rate(pg_stat_database_xact_rollback{datname=\"urban_erp\"}[5m])", "legendFormat": "tps", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Connection States Over Time",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_activity_count{datname=\"urban_erp\",state=\"active\"}", "legendFormat": "active", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_activity_count{datname=\"urban_erp\",state=\"idle\"}", "legendFormat": "idle", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_activity_count{datname=\"urban_erp\",state=\"idle in transaction\"}", "legendFormat": "idle in txn", "refId": "C"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Transactions/s",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_xact_commit{datname=\"urban_erp\"}[5m])", "legendFormat": "commits/s", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_xact_rollback{datname=\"urban_erp\"}[5m])", "legendFormat": "rollbacks/s", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Cache Hit Ratio Over Time",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_database_blks_hit{datname=\"urban_erp\"} / (pg_stat_database_blks_hit{datname=\"urban_erp\"} + pg_stat_database_blks_read{datname=\"urban_erp\"})", "legendFormat": "cache hit %", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Locks",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_locks_count{datname=\"urban_erp\"}", "legendFormat": "{{mode}}", "refId": "A"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["urban-vibes-dynamics", "postgresql"],
  "title": "Urban Vibes Dynamics — PostgreSQL Overview",
  "uid": "urban-vibes-dynamics-pg-overview",
  "version": 1
}
