        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "urban_erp_backup_age_seconds{backup_type=\"diff\"}", "legendFormat": "diff backup", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "86400", "legendFormat": "24h threshold", "refId": "C"}
