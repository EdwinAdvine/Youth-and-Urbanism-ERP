      "title": "Backup Status",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "min(urban_erp_backup_last_status)", "legendFormat": "status", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 67108864}, {"color": "red", "value": 134217728}]}, "unit": "bytes"},
