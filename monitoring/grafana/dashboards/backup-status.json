      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "urban_erp_wal_archive_lag_bytes", "legendFormat": "WAL lag", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
