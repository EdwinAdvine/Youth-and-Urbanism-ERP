{
  "__inputs": [],
  "__requires": [{"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"}],
  "annotations": {"list": []},
  "description": "Urban Vibes Dynamics — Patroni replication: per-standby lag, WAL positions, sync state, failover history",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}, "unit": "none"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Patroni Primary",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(patroni_master)", "legendFormat": "primary count", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1}, {"color": "green", "value": 2}]}, "unit": "none"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Healthy Replicas",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(patroni_replica)", "legendFormat": "replicas", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}]}, "unit": "decmbytes"}, "overrides": []},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["max"]}},
      "title": "Max Replication Lag",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "max(patroni_lag_in_mb)", "legendFormat": "max lag MB", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "decmbytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 4,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Replication Lag per Node (MB)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "patroni_lag_in_mb", "legendFormat": "{{instance}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "none"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Patroni Node Status (1=leader, 0.5=replica, 0=down)",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "patroni_master", "legendFormat": "{{instance}} leader", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "patroni_replica", "legendFormat": "{{instance}} replica", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "decmbytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "WAL Archive Lag",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "urban_erp_wal_archive_lag_bytes / 1048576", "legendFormat": "WAL archive lag MB", "refId": "A"}]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["urban-vibes-dynamics", "patroni", "replication"],
  "title": "Urban Vibes Dynamics — Replication",
  "uid": "urban-vibes-dynamics-replication",
  "version": 1
}
